#!/bin/bash
# --------------------------------------------------------------------------------
#  kiosk.env
# --------------------------------------------------------------------------------
#  Central configuration for KCC Pi Kiosk
#  Contains camera credentials, IP addresses, RTSP URLs, and kiosk advertising URLs
#
#  This file is downloaded automatically to each Pi via do_auto_update()
#  in kiosk.sh. Any changes made here will be picked up by all Pis on
#  the next SSH login.
#
#  Version 9.7
# --------------------------------------------------------------------------------
#  (C) Copyright Gareth Jones - gareth@gareth.com
# --------------------------------------------------------------------------------

# --------------------------------------------------------------------------------
# Software version
# --------------------------------------------------------------------------------
KCC_VERSION="9.7"

# --------------------------------------------------------------------------------
# Camera credentials
# --------------------------------------------------------------------------------
CAM_USER="root"
CAM_PASS="missionav"

# --------------------------------------------------------------------------------
# Home cameras (indexed 1-12, index 0 is unused)
# --------------------------------------------------------------------------------
